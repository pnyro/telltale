{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Telltale",
  "version": "0.1.0",
  "identifier": "com.telltale.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Telltale",
        "width": 1180,
        "height": 760,
        "minWidth": 640,
        "minHeight": 560,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
